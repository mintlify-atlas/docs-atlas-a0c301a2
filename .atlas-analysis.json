  "keyFeatures": [
    "Full Minecraft Classic server protocol implementation over TCP",
    "WebSocket support for ClassiCube browser clients via UpgradingHttpServer",
    "Classic Protocol Extension (CPE) negotiation and management",
    "13 built-in CPE extensions including BlockDefinitions, ExtendedPlayerList, and more",
    "Code Page 437 character encoding/decoding",
    "Extensible architecture via BaseExtension for custom CPE extensions",
    "Event-driven API using TypedEmitter for type-safe event handling"
  ],
